{
  "info": {
    "name": "Job Apply API",
    "description": "Complete API reference for the Job Application Agent (https://job-apply-corey.fly.dev/).\n\n**Auth model:** stateless HMAC session cookie (`session`). Login/register set the cookie automatically. All protected requests include it. Admins also accepted via `Authorization: Bearer {BOT_API_KEY}` header.\n\n**Run lifecycle (application & prep):**\n1. POST to start → returns `run_id` / `prep_id`\n2. GET `…/stream` → SSE; events: `progress`, `done`, `error`\n3. `done` event contains `files` with filenames\n4. GET `…/files/{name}` → download DOCX\n\n**Base URL:** `{{base_url}}` defaults to `https://job-apply-corey.fly.dev`. Override with `http://localhost:8000` for local dev.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",    "value": "https://job-apply-corey.fly.dev", "type": "string" },
    { "key": "run_id",      "value": "", "type": "string", "description": "UUID from POST /api/run" },
    { "key": "prep_id",     "value": "", "type": "string", "description": "UUID from POST /api/prep" },
    { "key": "app_id",      "value": "", "type": "string", "description": "UUID from POST /api/applications" },
    { "key": "comment_id",  "value": "", "type": "string", "description": "UUID from POST /api/applications/{id}/comments" },
    { "key": "webhook_id",  "value": "", "type": "string", "description": "UUID from POST /api/admin/webhooks" },
    { "key": "folder_id",   "value": "", "type": "string", "description": "Google Drive folder ID from GET /api/gdrive/runs" },
    { "key": "user_id",     "value": "", "type": "string", "description": "User UUID for admin endpoints" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [{
        "name": "GET /api/health",
        "request": {
          "method": "GET", "url": "{{base_url}}/api/health",
          "description": "Liveness check. Returns `{\"status\": \"ok\", \"storage\": true/false}`. No auth required."
        },
        "response": [{ "name": "200 OK", "status": "OK", "code": 200, "body": "{\"status\": \"ok\", \"storage\": true}" }]
      }]
    },
    {
      "name": "Auth",
      "description": "Session-based auth using an HMAC-signed `HttpOnly` cookie (30-day TTL). Google OAuth also supported. Email verification required before outbound emails are sent.",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/register",
            "description": "Create account. `multipart/form-data` so resume DOCX can be included. Sets session cookie on success. Sends verification email via Resend.",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "display_name", "value": "Corey Laverdiere", "type": "text" },
                { "key": "email",        "value": "you@example.com",   "type": "text" },
                { "key": "password",     "value": "minimum8chars",     "type": "text" },
                { "key": "profile_text", "value": "## Voice…",         "type": "text" },
                { "key": "resume",       "value": "",                  "type": "file" }
              ]
            }
          }
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/login",
            "description": "Authenticate with email and password. Sets session cookie.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"you@example.com\",\n  \"password\": \"your-password\"\n}" }
          }
        },
        {
          "name": "POST /api/auth/logout",
          "request": { "method": "POST", "url": "{{base_url}}/api/auth/logout", "description": "Clears session cookie." }
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/auth/me",
            "description": "Current user info including `role`, `email_verified`, `has_resume`, `has_profile`."
          }
        },
        {
          "name": "GET /api/auth/google",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/auth/google?returnTo=/tracking.html",
            "description": "Redirects to Google OAuth consent screen. `returnTo` is the path to redirect back to after auth (admins are always sent to /admin.html)."
          }
        },
        {
          "name": "GET /api/auth/google/callback",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/auth/google/callback",
            "description": "Google OAuth callback. Handled by the browser redirect — do not call directly."
          }
        },
        {
          "name": "GET /api/auth/verify-email",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/auth/verify-email?token=TOKEN",
            "description": "Public endpoint. Consumes a one-time verification token, marks the user as verified, and redirects to /login.html?verified=1."
          }
        },
        {
          "name": "POST /api/auth/resend-verification",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/resend-verification",
            "description": "Resend verification email for the current user. Returns `{\"ok\": true, \"already_verified\": true}` if already verified."
          }
        }
      ]
    },
    {
      "name": "Profile",
      "description": "Manage display name, profile guide (Markdown), master resume DOCX, and password.",
      "item": [
        {
          "name": "GET /api/profile",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/profile",
            "description": "Returns display name, email, role, email_verified, profile text, has_resume, resume_filename."
          }
        },
        {
          "name": "PUT /api/profile",
          "request": {
            "method": "PUT", "url": "{{base_url}}/api/profile",
            "description": "Update display name and/or profile guide text. Both optional.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"display_name\": \"Corey L.\",\n  \"profile_text\": \"Updated guide…\"\n}" }
          }
        },
        {
          "name": "POST /api/profile/resume",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/profile/resume",
            "description": "Replace master resume. Must be a .docx file ≥ 1 KB.",
            "body": { "mode": "formdata", "formdata": [{ "key": "resume", "value": "", "type": "file" }] }
          }
        },
        {
          "name": "POST /api/profile/password",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/profile/password",
            "description": "Change password. Requires current password. Sends confirmation email if RESEND_API_KEY is set.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"old\",\n  \"new_password\": \"new-min-8\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Application Tracker",
      "description": "Full CRUD for job applications. All data is scoped to the authenticated user. Index fields returned by the list endpoint; full records include comments, audit_log, and linked_runs.",
      "item": [
        {
          "name": "GET /api/applications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/applications?page=1&per_page=25&status=Interviewing", "host": ["{{base_url}}"], "path": ["api","applications"], "query": [{"key":"page","value":"1"},{"key":"per_page","value":"25"},{"key":"status","value":"Interviewing"}] },
            "description": "List applications (paginated). Optional filters: `status`, `priority`, `page`, `per_page` (0 = all). Returns `{items, total, page, per_page, pages}`."
          }
        },
        {
          "name": "POST /api/applications",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/applications",
            "description": "Create a new application. `url` must start with http:// or https:// if provided.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"company\": \"Salesforce\",\n  \"domain\": \"salesforce.com\",\n  \"role_title\": \"Solution Engineer\",\n  \"status\": \"Applied\",\n  \"priority\": \"High\",\n  \"url\": \"https://salesforce.com/careers/…\",\n  \"job_source\": \"LinkedIn\",\n  \"location\": \"Remote\",\n  \"salary_range\": \"$130k–$160k\",\n  \"dua\": false\n}" }
          }
        },
        {
          "name": "GET /api/applications/{app_id}",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/applications/{{app_id}}",
            "description": "Full application record including comments, audit_log, and linked_runs arrays."
          }
        },
        {
          "name": "PUT /api/applications/{app_id}",
          "request": {
            "method": "PUT", "url": "{{base_url}}/api/applications/{{app_id}}",
            "description": "Partial update — send only changed fields. Diffs are recorded in the application audit_log.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Interviewing\",\n  \"recruiter_name\": \"Jane Smith\",\n  \"recruiter_email\": \"jane@salesforce.com\"\n}" }
          }
        },
        {
          "name": "DELETE /api/applications/{app_id}",
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/applications/{{app_id}}",
            "description": "Delete application. A tombstone is saved before deletion for audit purposes. Returns 204."
          }
        },
        {
          "name": "GET /api/applications/{app_id}/audit",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/applications/{{app_id}}/audit",
            "description": "Returns the application-level audit_log array (create, update, delete, comment, run-link events)."
          }
        },
        {
          "name": "POST /api/applications/{app_id}/comments",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/applications/{{app_id}}/comments",
            "description": "Add a comment. Returns the created comment object.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Recruiter confirmed HM interview for Monday.\"\n}" }
          }
        },
        {
          "name": "PUT /api/applications/{app_id}/comments/{comment_id}",
          "request": {
            "method": "PUT", "url": "{{base_url}}/api/applications/{{app_id}}/comments/{{comment_id}}",
            "description": "Edit an existing comment.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Updated note text.\"\n}" }
          }
        },
        {
          "name": "DELETE /api/applications/{app_id}/comments/{comment_id}",
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/applications/{{app_id}}/comments/{{comment_id}}",
            "description": "Delete a comment. Returns 204."
          }
        },
        {
          "name": "POST /api/applications/{app_id}/runs",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/applications/{{app_id}}/runs",
            "description": "Link a Drive run folder to an application. Auto-called when a run is started with `app_id`.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"resume\",\n  \"folder_name\": \"Salesforce_SolutionEngineer\",\n  \"folder_url\": \"https://drive.google.com/drive/folders/…\",\n  \"gdrive_folder_id\": \"1abc123\"\n}" }
          }
        },
        {
          "name": "DELETE /api/applications/{app_id}/runs/{link_id}",
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/applications/{{app_id}}/runs/{{link_id}}",
            "description": "Unlink a Drive run from an application. Returns 204."
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [{
        "name": "GET /api/companies/search",
        "request": {
          "method": "GET",
          "url": { "raw": "{{base_url}}/api/companies/search?q=salesforce", "host": ["{{base_url}}"], "path": ["api","companies","search"], "query": [{"key":"q","value":"salesforce"}] },
          "description": "BrandFetch company search. Returns up to 5 results: `{name, domain, logo_url, description}`. Public endpoint — no auth required. Used by the tracker's company picker dropdown."
        }
      }]
    },
    {
      "name": "Application Runs",
      "description": "Start and monitor a resume + cover letter generation run.\n\nLifecycle: POST → SSE stream → done event contains file names → download files.\nRuns are serialised server-side — only one active at a time; queue auto-drains.",
      "item": [
        {
          "name": "POST /api/run",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/run",
            "description": "Start a run. Optional `app_id` links the completed run to an application tracker record.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"job_posting\": \"Paste full JD here…\",\n  \"company\": \"Acme Corp\",\n  \"role\": \"Solutions Engineer\",\n  \"contact\": \"Jane Smith\",\n  \"app_id\": \"optional-application-uuid\"\n}" }
          }
        },
        {
          "name": "GET /api/run/{run_id}/stream",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/run/{{run_id}}/stream",
            "description": "SSE stream. Events: `progress` (log line), `done` (files + folder_url), `error`. Keep-alives every 30s.",
            "header": [{ "key": "Accept", "value": "text/event-stream" }]
          }
        },
        {
          "name": "GET /api/run/{run_id}/status",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/run/{{run_id}}/status",
            "description": "Poll run status: `queued | running | done | error`."
          }
        },
        {
          "name": "GET /api/run/{run_id}/files/{filename}",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/run/{{run_id}}/files/Resume_CoreyLaverdiere_Acme_SolutionsEngineer.docx",
            "description": "Download output DOCX. Filename from `files` in the `done` SSE event. Returns 403 if run belongs to another user."
          }
        }
      ]
    },
    {
      "name": "Interview Prep Runs",
      "description": "Same lifecycle as Application Runs. `done` event returns `files.prep` (single DOCX). Output is a two-column 9-section reference card.\n\n`round_type` must be: `Phone Screen`, `Hiring Manager`, `Peer`, `Technical`, `Executive`, `Panel`.",
      "item": [
        {
          "name": "POST /api/prep",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/prep",
            "description": "Start a prep run. Optional `interviewer` and `focus` for calibration. Optional `app_id` links the run to a tracker record.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"job_posting\": \"Paste full JD here…\",\n  \"company\": \"Acme Corp\",\n  \"role\": \"Solutions Engineer\",\n  \"round_type\": \"Hiring Manager\",\n  \"interviewer\": \"Jane Smith — Engineering Manager\",\n  \"focus\": \"Lean into the agentic AI angle\",\n  \"app_id\": \"optional-application-uuid\"\n}" }
          }
        },
        {
          "name": "GET /api/prep/{prep_id}/stream",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/prep/{{prep_id}}/stream",
            "description": "SSE stream for prep run. Same event format as application runs.",
            "header": [{ "key": "Accept", "value": "text/event-stream" }]
          }
        },
        {
          "name": "GET /api/prep/{prep_id}/status",
          "request": { "method": "GET", "url": "{{base_url}}/api/prep/{{prep_id}}/status", "description": "Poll prep status." }
        },
        {
          "name": "GET /api/prep/{prep_id}/files/{filename}",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/prep/{{prep_id}}/files/InterviewPrep_Acme_SolutionsEngineer_HiringManager.docx",
            "description": "Download prep DOCX. Returns 403 if prep belongs to another user."
          }
        }
      ]
    },
    {
      "name": "Google Drive",
      "description": "Proxy endpoints for listing run folders and fetching saved job descriptions. Drive is configured server-side.",
      "item": [
        {
          "name": "GET /api/gdrive/runs",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/gdrive/runs",
            "description": "List all run folders for the current user. Each entry: `{id, name, web_view_link, source: 'user'|'legacy'}`."
          }
        },
        {
          "name": "GET /api/gdrive/runs/{folder_id}/job_posting",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/gdrive/runs/{{folder_id}}/job_posting",
            "description": "Fetch `job_posting.txt` from a Drive folder. Returns 404 if not saved."
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [{
        "name": "GET /api/audit/me",
        "request": {
          "method": "GET", "url": "{{base_url}}/api/audit/me",
          "description": "Returns the current user's audit event log (newest first). Each event: `{id, action, actor, timestamp, ip, details}`."
        }
      }]
    },
    {
      "name": "Admin — Users",
      "description": "All endpoints require `role: admin`. Accept the session cookie or `Authorization: Bearer {BOT_API_KEY}`.",
      "item": [
        {
          "name": "GET /api/admin/users",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/users",
            "description": "List all users with app_count, last_login, email_verified, active status."
          }
        },
        {
          "name": "PUT /api/admin/users/{user_id}",
          "request": {
            "method": "PUT", "url": "{{base_url}}/api/admin/users/{{user_id}}",
            "description": "Edit display_name, email (safe rename across all indexes), role, email_verified, active.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"admin\",\n  \"active\": true,\n  \"email_verified\": true\n}" }
          }
        },
        {
          "name": "POST /api/admin/users/{user_id}/resend-verification",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/admin/users/{{user_id}}/resend-verification",
            "description": "Resend verification email to a specific user as admin."
          }
        }
      ]
    },
    {
      "name": "Admin — Applications",
      "item": [
        {
          "name": "GET /api/admin/applications",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/applications",
            "description": "All applications across all users. Each item includes `_user_id` and `_user_email`."
          }
        },
        {
          "name": "GET /api/admin/applications/{user_id}/{app_id}",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/applications/{{user_id}}/{{app_id}}",
            "description": "Full application record for any user."
          }
        },
        {
          "name": "PUT /api/admin/applications/{user_id}/{app_id}",
          "request": {
            "method": "PUT", "url": "{{base_url}}/api/admin/applications/{{user_id}}/{{app_id}}",
            "description": "Admin update any application.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Rejected\"\n}" }
          }
        },
        {
          "name": "DELETE /api/admin/applications/{user_id}/{app_id}",
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/admin/applications/{{user_id}}/{{app_id}}",
            "description": "Admin delete any application. Returns 204."
          }
        },
        {
          "name": "POST /api/admin/applications/{user_id}/{app_id}/comments",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/admin/applications/{{user_id}}/{{app_id}}/comments",
            "description": "Admin add comment to any application.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Admin note.\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin — Runs",
      "item": [{
        "name": "GET /api/admin/runs",
        "request": {
          "method": "GET", "url": "{{base_url}}/api/admin/runs",
          "description": "All Drive run folders across all users with type detection (resume vs interview_prep), created_at, and web_view_link. Also includes any still-active in-memory runs."
        }
      }]
    },
    {
      "name": "Admin — Audit Log",
      "item": [
        {
          "name": "GET /api/admin/audit",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/admin/audit?page=1&per_page=50&sort_order=desc", "host": ["{{base_url}}"], "path": ["api","admin","audit"], "query": [{"key":"page","value":"1"},{"key":"per_page","value":"50"},{"key":"sort_order","value":"desc"},{"key":"action","value":"","disabled":true},{"key":"actor","value":"","disabled":true},{"key":"user_id","value":"","disabled":true},{"key":"source","value":"","disabled":true},{"key":"event_id","value":"","disabled":true},{"key":"from_ts","value":"","disabled":true},{"key":"to_ts","value":"","disabled":true}] },
            "description": "Unified paginated audit log across all users and all application records. Filters: `action`, `actor`, `user_id`, `source` (user|application), `event_id`, `from_ts`, `to_ts` (ISO), `sort_order` (asc|desc)."
          }
        },
        {
          "name": "GET /api/admin/audit/export",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/audit/export",
            "description": "Full filtered audit result with no pagination. Same filters as GET /api/admin/audit. Logs admin_csv_export event. Used for CSV/Excel exports."
          }
        },
        {
          "name": "GET /api/admin/audit/action-types",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/audit/action-types",
            "description": "Returns sorted list of all known audit action type strings for filter dropdowns."
          }
        },
        {
          "name": "POST /api/admin/log-activity",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/admin/log-activity",
            "description": "Log a custom admin activity event (e.g. CSV export from the browser). Writes admin_csv_export to the audit log.",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"screen\": \"users_csv\",\n  \"row_count\": 2,\n  \"filters\": {\"role\": \"admin\"}\n}" }
          }
        }
      ]
    },
    {
      "name": "Admin — Webhooks",
      "description": "Create and manage outbound webhooks for event streaming. Webhooks fire on every user_audit.log() call that matches subscribed events and active filters.",
      "item": [
        {
          "name": "GET /api/admin/webhooks",
          "request": {
            "method": "GET", "url": "{{base_url}}/api/admin/webhooks",
            "description": "List all webhooks (summary from index)."
          }
        },
        {
          "name": "POST /api/admin/webhooks",
          "request": {
            "method": "POST", "url": "{{base_url}}/api/admin/webhooks",
            "description": "Create a webhook.\n\n`payload_format`: `generic` | `slack` | `ms_teams` | `grafana_loki`\n\nFilters (all AND, blank = skip):\n- `filter_actors`: comma-separated emails/user_ids\n- `filter_source`: `user` | `application`\n- `filter_categories`: array of `auth|profile|applications|runs|admin`\n- `filter_app_id`: specific application UUID\n\n`secret`: if set, deliveries include `X-Hub-Signature-256: sha256={hmac}`",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
