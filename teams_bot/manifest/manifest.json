{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.1.0",
  "id": "f71306b1-602b-496c-a579-7a8afa62be37",
  "developer": {
    "name": "Corey Laverdiere",
    "websiteUrl": "https://apply.cdlav.us",
    "privacyUrl": "https://apply.cdlav.us/privacy",
    "termsOfUseUrl": "https://apply.cdlav.us/terms"
  },
  "name": {
    "short": "Job Apply",
    "full": "Job Apply Agent"
  },
  "description": {
    "short": "AI-powered job application agent",
    "full": "Generate tailored resumes, ATS-optimized resumes, cover letters, and interview prep materials using AI. Track applications, manage your pipeline, and stay organized throughout your job search."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#1A3C5E",
  "bots": [
    {
      "botId": "f71306b1-602b-496c-a579-7a8afa62be37",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal"],
          "commands": [
            { "title": "apply", "description": "Generate resume + cover letter for a job" },
            { "title": "aq", "description": "Answer an application question" },
            { "title": "prep", "description": "Generate interview prep doc" },
            { "title": "optimize", "description": "Refine existing run documents" },
            { "title": "tracker", "description": "Pipeline summary" },
            { "title": "track", "description": "Manage applications (list, add, view)" },
            { "title": "confirm", "description": "Link your Teams identity to a Job Apply account" },
            { "title": "whoami", "description": "Show which account you're linked as" },
            { "title": "unlink", "description": "Remove your Teams identity's link" },
            { "title": "help", "description": "Command reference" }
          ]
        }
      ]
    }
  ],
  "validDomains": ["apply.cdlav.us"]
}
