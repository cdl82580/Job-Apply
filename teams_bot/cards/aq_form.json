{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Answer Application Question",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Generate a tailored answer to an application question using your resume and the JD.",
      "wrap": true,
      "spacing": "None",
      "isSubtle": true
    },
    {
      "type": "Input.ChoiceSet",
      "id": "app_id",
      "label": "Application",
      "style": "filtered",
      "isRequired": true,
      "errorMessage": "Select an application",
      "placeholder": "Search your tracked applications…",
      "choices": [],
      "choices.data": {
        "type": "Data.Query",
        "dataset": "myApplications"
      }
    },
    {
      "type": "Input.Text",
      "id": "question",
      "label": "Application question",
      "placeholder": "Why do you want to work at our company?",
      "isMultiline": true,
      "isRequired": true,
      "errorMessage": "Question is required"
    },
    {
      "type": "Input.ChoiceSet",
      "id": "tone",
      "label": "Tone",
      "value": "professional",
      "choices": [
        { "title": "Professional", "value": "professional" },
        { "title": "Conversational", "value": "conversational" },
        { "title": "Technical", "value": "technical" },
        { "title": "Concise", "value": "concise" }
      ]
    },
    {
      "type": "Input.Number",
      "id": "char_limit",
      "label": "Character limit (optional)",
      "placeholder": "500"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Continue",
      "data": {
        "action": "aq_select_submit"
      }
    }
  ]
}
