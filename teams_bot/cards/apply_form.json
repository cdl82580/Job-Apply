{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Generate Application",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Generate a tailored resume, ATS resume, and cover letter for a tracked application.",
      "wrap": true,
      "spacing": "None",
      "isSubtle": true
    },
    {
      "type": "Input.ChoiceSet",
      "id": "app_id",
      "label": "Application",
      "style": "filtered",
      "isRequired": true,
      "errorMessage": "Select an application",
      "placeholder": "Search your tracked applications…",
      "choices": [],
      "choices.data": {
        "type": "Data.Query",
        "dataset": "myApplications"
      }
    },
    {
      "type": "Input.Text",
      "id": "contact",
      "label": "Hiring manager name (optional)",
      "placeholder": "Jane Smith"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Continue",
      "data": {
        "action": "apply_select_submit"
      }
    }
  ]
}
