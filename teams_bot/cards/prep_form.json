{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Interview Prep",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "TextBlock",
      "text": "Generate an interview prep reference card for a tracked application.",
      "wrap": true,
      "spacing": "None",
      "isSubtle": true
    },
    {
      "type": "Input.ChoiceSet",
      "id": "app_id",
      "label": "Application",
      "style": "filtered",
      "isRequired": true,
      "errorMessage": "Select an application",
      "placeholder": "Search your tracked applications…",
      "choices": [],
      "choices.data": {
        "type": "Data.Query",
        "dataset": "myApplications"
      }
    },
    {
      "type": "Input.ChoiceSet",
      "id": "round_type",
      "label": "Interview round",
      "isRequired": true,
      "errorMessage": "Round type is required",
      "choices": [
        { "title": "Recruiter Screen", "value": "recruiter_screen" },
        { "title": "Hiring Manager", "value": "hiring_manager" },
        { "title": "Technical", "value": "technical" },
        { "title": "Panel", "value": "panel" },
        { "title": "Final", "value": "final" },
        { "title": "Take Home", "value": "take_home" }
      ]
    },
    {
      "type": "Input.Text",
      "id": "interviewer",
      "label": "Interviewer name (optional)",
      "placeholder": "John Doe"
    },
    {
      "type": "Input.Text",
      "id": "focus",
      "label": "Focus areas (optional)",
      "placeholder": "API design, system architecture"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Continue",
      "data": {
        "action": "prep_select_submit"
      }
    }
  ]
}
